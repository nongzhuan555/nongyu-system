    "iconv-lite": "catalog:",
    "mitt": "catalog:",
    "zod": "^3.23.0",
    "nongyu-tool-jiaowu": "workspace:*",
    "nongyu-tool-second": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tsx": "^4.19.2"
  }
