{
  "name": "nongyu-system",
  "version": "1.0.0",
  "description": "农屿系统，本项目使用单仓架构管理农屿系统下的所有产品以及工具库",
  "author": "tanglei",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
